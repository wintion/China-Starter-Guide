{
  "name": "radiant-remnant",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist --glob \"{index.html,category/**/*.html,guides/**/*.html,search/**/*.html,fr/**/*.html,zh/**/*.html,ja/**/*.html,ko/**/*.html,th/**/*.html,id/**/*.html,vi/**/*.html,ar/**/*.html}\"",
    "preview": "astro preview",
    "localize:guides": "python3 scripts/localize_guides.py",
    "localize:cleanup": "python3 scripts/cleanup_localized_guides.py",
    "localize:check": "python3 scripts/cleanup_localized_guides.py --check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.16.6",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "pagefind": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
