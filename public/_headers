# Cache pagefind assets aggressively
/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# Cache static assets
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
