---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { getLangFromPath, withOptionalLangPrefix } from '../utils/i18n';

const lang = getLangFromPath(Astro.url.pathname);
const withLang = (path: string) => withOptionalLangPrefix(path, lang);
---

<header>
	<nav>
		<h2><a href={withLang('/')}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={withLang('/')}>Home</HeaderLink>
			<HeaderLink href={withLang('/blog')}>Blog</HeaderLink>
			<HeaderLink href={withLang('/about')}>About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
