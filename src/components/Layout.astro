---
import { getLangFromPath, withOptionalLangPrefix } from '../utils/i18n';

const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const lang = getLangFromPath(currentPath);
const withLang = (path: string) => withOptionalLangPrefix(path, lang);
const isActive = (href: string) => {
	const localized = withLang(href);
	return currentPath === localized || (href !== '/' && currentPath.startsWith(`${localized}/`));
};
---

<header class="site-header">
	<div class="site-bar">
		<a class="site-title" href={withLang('/')}>
			<img class="site-logo" src="/logo.svg" alt="China Starter Guide" width="400" height="100" />
		</a>
		<nav class="site-nav" aria-label="Primary">
			<a href={withLang('/category/prepare')} aria-current={isActive('/category/prepare') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M9 6h10" />
					<path d="M9 12h10" />
					<path d="M9 18h10" />
					<path d="M5 6l1 1 2-2" />
					<path d="M5 12l1 1 2-2" />
					<path d="M5 18l1 1 2-2" />
				</svg>
				Prepare
			</a>
			<a href={withLang('/category/payment')} aria-current={isActive('/category/payment') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M4 8h16v10H4z" />
					<path d="M4 11h16" />
					<path d="M8 15h4" />
				</svg>
				Payment
			</a>
			<a href={withLang('/category/transport')} aria-current={isActive('/category/transport') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M7 4h10v11a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3z" />
					<path d="M7 8h10" />
					<path d="M9 12h2" />
					<path d="M13 12h2" />
					<path d="M9 19l-2 2" />
					<path d="M15 19l2 2" />
				</svg>
				Transport
			</a>
			<a href={withLang('/category/life')} aria-current={isActive('/category/life') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M4 11l8-6 8 6" />
					<path d="M6 10v8h12v-8" />
				</svg>
				Life
			</a>
			<a href={withLang('/category/cities')} aria-current={isActive('/category/cities') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M3 19h18" />
					<path d="M6 19V9h4v10" />
					<path d="M12 19V6h4v13" />
					<path d="M18 19v-7h3v7" />
				</svg>
				Cities
			</a>
			<a href={withLang('/category/tips')} aria-current={isActive('/category/tips') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M9 18h6" />
					<path d="M10 22h4" />
					<path d="M8 10a4 4 0 118 0c0 2-1.2 3-2.4 4.2-.6.6-1.1 1.4-1.1 2.8h-2c0-1.4-.5-2.2-1.1-2.8C9.2 13 8 12 8 10z" />
				</svg>
				Tips
			</a>
			<a href={withLang('/search')} aria-current={isActive('/search') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="11" cy="11" r="6" />
					<path d="M16 16l4 4" />
				</svg>
				Search
			</a>
			<a href={withLang('/about')} aria-current={isActive('/about') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="12" cy="12" r="9" />
					<path d="M12 10v6" />
					<path d="M12 7h0.01" />
				</svg>
				About
			</a>
		</nav>
	</div>
</header>

<div data-pagefind-body>
	<slot />
</div>

<footer class="site-footer">
	<div class="footer-inner">
		<p>&copy; {year} China Starter Guide. All rights reserved.</p>
		<nav class="footer-links" aria-label="Footer">
			<a href={withLang('/about')}>About</a>
			<a href="https://github.com/wintion/China-Starter-Guide/issues/new" target="_blank" rel="noreferrer">
				Open an Issue
			</a>
		</nav>
	</div>
</footer>

<style>
	.site-header {
		background: linear-gradient(180deg, rgba(255, 250, 240, 0.95), rgba(255, 245, 230, 0.9));
		border-bottom: 1px solid rgb(var(--stroke));
		box-shadow: 0 8px 20px rgba(46, 34, 20, 0.08);
	}
	.site-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 1.25rem 1rem;
	}
	.site-title {
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.site-logo {
		width: 400px;
		height: auto;
		filter: drop-shadow(0 6px 12px rgba(46, 34, 20, 0.12));
	}
	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
	}
	.site-nav a {
		color: rgb(var(--black));
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		padding: 0.35rem 0.85rem;
		border-radius: 999px;
		border: 1px solid transparent;
		background: rgba(47, 111, 85, 0.08);
		transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		line-height: 1;
		white-space: nowrap;
	}
	.nav-icon {
		width: 16px;
		height: 16px;
		padding: 2px;
		box-sizing: content-box;
		stroke: currentColor;
		stroke-width: 1.6;
		fill: none;
		stroke-linecap: round;
		stroke-linejoin: round;
		color: var(--accent);
		background: rgba(47, 111, 85, 0.16);
		border-radius: 6px;
	}
	.site-nav a[aria-current="page"] {
		background: rgba(47, 111, 85, 0.22);
		border-color: rgba(47, 111, 85, 0.45);
		color: var(--accent-dark);
		box-shadow: inset 0 0 0 1px rgba(47, 111, 85, 0.2);
	}
	.site-nav a:hover {
		color: var(--accent-dark);
		background: rgba(47, 111, 85, 0.16);
		border-color: rgba(47, 111, 85, 0.25);
		transform: translateY(-1px);
	}
	.site-footer {
		border-top: 1px solid rgb(var(--stroke));
		padding: 2.5rem 1rem 3rem;
		color: rgb(var(--gray));
		background: linear-gradient(180deg, rgba(255, 250, 240, 0.8), rgba(255, 245, 230, 0.95));
	}
	.footer-inner {
		max-width: var(--content-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.site-footer p {
		margin: 0;
	}
	.footer-links {
		display: inline-flex;
		gap: 0.9rem;
		flex-wrap: wrap;
	}
	.footer-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 600;
	}
	.footer-links a:hover {
		color: var(--accent-dark);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	@media (max-width: 900px) {
		.site-bar {
			flex-direction: column;
			align-items: flex-start;
		}
		.site-logo {
			width: min(90vw, 380px);
		}
	}
</style>
