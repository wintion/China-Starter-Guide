---
const year = new Date().getFullYear();
---

<header class="site-header">
	<div class="site-bar">
		<a class="site-title" href="/">China Starter Guide</a>
		<nav class="site-nav" aria-label="Primary">
			<a href="/category/prepare">Prepare</a>
			<a href="/category/payment">Payment</a>
			<a href="/category/transport">Transport</a>
			<a href="/category/life">Life</a>
			<a href="/category/cities">Cities</a>
			<a href="/category/tips">Tips</a>
			<a href="/search">Search</a>
		</nav>
	</div>
</header>

<slot />

<footer class="site-footer">
	<p>&copy; {year} China Starter Guide. All rights reserved.</p>
</footer>

<style>
	.site-header {
		background: #fff;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.site-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 1rem;
	}
	.site-title {
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.site-nav a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.95rem;
		padding: 0.15rem 0;
	}
	.site-nav a:hover {
		color: var(--accent);
	}
	.site-footer {
		border-top: 1px solid rgb(var(--gray-light));
		padding: 2rem 1rem 3rem;
		text-align: center;
		color: rgb(var(--gray));
	}
	.site-footer p {
		margin: 0;
	}
</style>
