---
import {
	DEFAULT_LANG,
	LANGUAGE_OPTIONS,
	getLangFromPath,
	getLanguageOption,
	stripLangFromPath,
	withOptionalLangPrefix,
} from '../utils/i18n';
import { getCategoryLabel, getLayoutCopy } from '../utils/localized-copy';

const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const lang = getLangFromPath(currentPath);
const withLang = (path: string) => withOptionalLangPrefix(path, lang);
const currentLanguage = getLanguageOption(lang);
const layoutCopy = getLayoutCopy(lang);
const languageBasePath = stripLangFromPath(currentPath) || '/';
const languageHref = (targetLang: (typeof LANGUAGE_OPTIONS)[number]['code']) =>
	withOptionalLangPrefix(languageBasePath, targetLang, DEFAULT_LANG);
const shouldShowEnglishLabel = (code: string) => code !== 'en';
const isActive = (href: string) => {
	const localized = withLang(href);
	return currentPath === localized || (href !== '/' && currentPath.startsWith(`${localized}/`));
};
---

<header class="site-header">
	<div class="site-bar">
		<div class="site-top">
			<a class="site-title" href={withLang('/')}>
				<img class="site-logo" src="/logo.svg" alt="China Starter Guide" width="400" height="100" />
			</a>
			<div class="language-picker" data-language-picker>
				<button
					type="button"
					class="language-trigger"
					aria-label={`${layoutCopy.language}: ${currentLanguage.label}`}
					aria-expanded="false"
					aria-controls="language-popover"
					data-language-trigger
				>
					<span class="sr-only">{layoutCopy.language}</span>
					<svg class="language-icon" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="9" />
						<path d="M3 12h18" />
						<path d="M12 3a15 15 0 0 1 0 18" />
						<path d="M12 3a15 15 0 0 0 0 18" />
						<path d="M6 7.5h12" />
						<path d="M6 16.5h12" />
					</svg>
					<svg class="language-chevron" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M6 9l6 6 6-6" />
					</svg>
				</button>
				<div class="lang-menu-popover" id="language-popover" hidden data-language-popover>
					<ul class="lang-menu-list" aria-label="Available languages">
						{LANGUAGE_OPTIONS.filter((language) => language.isLive).map((language) => (
							<li>
								<a
									href={languageHref(language.code)}
									class:list={['lang-menu-item', language.code === lang && 'is-current']}
									data-language-link
									data-language-code={language.code}
								>
									<span class="lang-menu-labels">
										<strong class="lang-menu-native" dir="auto">{language.nativeLabel}</strong>
										<span
											class:list={[
												'lang-menu-english',
												!shouldShowEnglishLabel(language.code) && 'is-placeholder',
											]}
										>
											{shouldShowEnglishLabel(language.code) ? language.label : language.label}
										</span>
									</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
		<nav class="site-nav" aria-label="Primary">
			<a href={withLang('/category/prepare')} aria-current={isActive('/category/prepare') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M9 6h10" />
					<path d="M9 12h10" />
					<path d="M9 18h10" />
					<path d="M5 6l1 1 2-2" />
					<path d="M5 12l1 1 2-2" />
					<path d="M5 18l1 1 2-2" />
				</svg>
				{getCategoryLabel('prepare', lang)}
			</a>
			<a href={withLang('/category/payment')} aria-current={isActive('/category/payment') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M4 8h16v10H4z" />
					<path d="M4 11h16" />
					<path d="M8 15h4" />
				</svg>
				{getCategoryLabel('payment', lang)}
			</a>
			<a href={withLang('/category/transport')} aria-current={isActive('/category/transport') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M7 4h10v11a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3z" />
					<path d="M7 8h10" />
					<path d="M9 12h2" />
					<path d="M13 12h2" />
					<path d="M9 19l-2 2" />
					<path d="M15 19l2 2" />
				</svg>
				{getCategoryLabel('transport', lang)}
			</a>
			<a href={withLang('/category/life')} aria-current={isActive('/category/life') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M4 11l8-6 8 6" />
					<path d="M6 10v8h12v-8" />
				</svg>
				{getCategoryLabel('life', lang)}
			</a>
			<a
				href={withLang('/category/medical')}
				aria-current={isActive('/category/medical') ? 'page' : undefined}
			>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M12 4v16" />
					<path d="M4 12h16" />
					<path d="M6 6l12 12" />
					<path d="M18 6L6 18" />
				</svg>
				{getCategoryLabel('medical', lang)}
			</a>
			<a href={withLang('/category/cities')} aria-current={isActive('/category/cities') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M3 19h18" />
					<path d="M6 19V9h4v10" />
					<path d="M12 19V6h4v13" />
					<path d="M18 19v-7h3v7" />
				</svg>
				{getCategoryLabel('cities', lang)}
			</a>
			<a href={withLang('/category/tips')} aria-current={isActive('/category/tips') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M9 18h6" />
					<path d="M10 22h4" />
					<path d="M8 10a4 4 0 118 0c0 2-1.2 3-2.4 4.2-.6.6-1.1 1.4-1.1 2.8h-2c0-1.4-.5-2.2-1.1-2.8C9.2 13 8 12 8 10z" />
				</svg>
				{getCategoryLabel('tips', lang)}
			</a>
			<a href={withLang('/search')} aria-current={isActive('/search') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="11" cy="11" r="6" />
					<path d="M16 16l4 4" />
				</svg>
				{layoutCopy.search}
			</a>
			<a href={withLang('/about')} aria-current={isActive('/about') ? 'page' : undefined}>
				<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="12" cy="12" r="9" />
					<path d="M12 10v6" />
					<path d="M12 7h0.01" />
				</svg>
				{layoutCopy.about}
			</a>
		</nav>
	</div>
</header>

<div data-pagefind-body>
	<slot />
</div>

<footer class="site-footer">
	<div class="footer-inner">
		<p>&copy; {year} China Starter Guide. {layoutCopy.footerRights}</p>
		<nav class="footer-links" aria-label="Footer">
			<a href={withLang('/about')}>{layoutCopy.about}</a>
			<a href="mailto:contact@chinastarterguide.com">
				{layoutCopy.contact}
			</a>
		</nav>
	</div>
</footer>

<script is:inline>
	document.querySelectorAll('[data-language-picker]').forEach((picker) => {
		const trigger = picker.querySelector('[data-language-trigger]');
		const popover = picker.querySelector('[data-language-popover]');
		if (!(trigger instanceof HTMLButtonElement) || !(popover instanceof HTMLElement)) return;

		const closePopover = () => {
			trigger.setAttribute('aria-expanded', 'false');
			popover.hidden = true;
		};

		const openPopover = () => {
			trigger.setAttribute('aria-expanded', 'true');
			popover.hidden = false;
		};

		trigger.addEventListener('click', () => {
			if (popover.hidden) {
				openPopover();
			} else {
				closePopover();
			}
		});

		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node) || picker.contains(event.target)) return;
			closePopover();
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closePopover();
			}
		});

		picker.querySelectorAll('[data-language-link]').forEach((link) => {
			link.addEventListener('click', () => {
				const code = link.getAttribute('data-language-code');
				if (code) {
					window.localStorage.setItem('preferred-language', code);
				}
				closePopover();
			});
		});
	});
</script>

<style>
	.site-header {
		background: linear-gradient(180deg, rgba(255, 250, 240, 0.95), rgba(255, 245, 230, 0.9));
		border-bottom: 1px solid rgb(var(--stroke));
		box-shadow: 0 8px 20px rgba(46, 34, 20, 0.08);
	}
	.site-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0;
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 1.25rem 1rem;
	}
	.site-top {
		width: 100%;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: start;
		gap: 1rem;
	}
	.site-title {
		font-weight: 700;
		color: rgb(var(--black));
		text-decoration: none;
	}
	.site-logo {
		width: 500px;
		height: auto;
		max-width: 100%;
		filter: drop-shadow(0 6px 12px rgba(46, 34, 20, 0.12));
	}
	.language-picker {
		position: relative;
		flex: 0 0 auto;
		justify-self: end;
	}
	.language-trigger {
		appearance: none;
		-webkit-appearance: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.38rem;
		padding: 0.42rem 0.62rem;
		min-width: 72px;
		min-height: 44px;
		border-radius: 999px;
		border: 1px solid rgba(47, 111, 85, 0.2);
		background: rgba(255, 250, 240, 0.96);
		color: rgb(var(--black));
		font: inherit;
		font-size: 0.88rem;
		font-weight: 700;
		cursor: pointer;
		box-shadow: 0 8px 16px rgba(46, 34, 20, 0.08);
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background 0.2s ease;
	}
	.language-trigger:hover {
		transform: translateY(-1px);
		border-color: rgba(47, 111, 85, 0.34);
		box-shadow: var(--shadow-soft);
	}
	.language-trigger[aria-expanded="true"] {
		border-color: rgba(47, 111, 85, 0.38);
		box-shadow: var(--shadow-soft);
	}
	.language-icon,
	.language-chevron {
		flex: 0 0 auto;
		stroke: currentColor;
		fill: none;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	.language-icon {
		width: 20px;
		height: 20px;
		stroke-width: 1.7;
		color: var(--accent-dark);
	}
	.language-chevron {
		width: 16px;
		height: 16px;
		stroke-width: 2.1;
		color: rgb(var(--gray-dark));
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	.lang-menu-popover {
		position: absolute;
		top: calc(100% + 0.18rem);
		right: 0;
		width: 184px;
		max-width: calc(100vw - 0.75rem);
		padding: 0.18rem 0;
		border-radius: 18px;
		border: 1px solid rgba(47, 111, 85, 0.12);
		background: linear-gradient(180deg, rgba(255, 252, 246, 0.99), rgba(255, 248, 239, 0.985));
		box-shadow:
			0 10px 24px rgba(46, 34, 20, 0.08),
			0 2px 0 rgba(255, 255, 255, 0.5) inset;
		backdrop-filter: blur(12px);
		z-index: 20;
		overflow: hidden;
	}
	.lang-menu-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
		max-height: min(calc(100vh - 8rem), 440px);
		overflow-y: auto;
		overflow-x: hidden;
		overscroll-behavior: contain;
	}
	.lang-menu-list li {
		min-width: 0;
		border-top: 1px solid rgba(47, 111, 85, 0.06);
	}
	.lang-menu-list li:first-child {
		border-top: 0;
	}
	.lang-menu-item {
		appearance: none;
		-webkit-appearance: none;
		position: relative;
		width: 100%;
		display: block;
		padding: 0.38rem 1.05rem 0.38rem 0.52rem;
		border: 0;
		border-radius: 0;
		box-sizing: border-box;
		background: transparent;
		color: rgb(var(--black));
		text-decoration: none;
		text-align: left;
		font: inherit;
		line-height: 1;
		transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.lang-menu-item:hover {
		background: rgba(47, 111, 85, 0.055);
	}
	.lang-menu-item.is-current {
		background: rgba(47, 111, 85, 0.07);
	}
	.lang-menu-item.is-current .lang-menu-native {
		color: var(--accent-dark);
	}
	.lang-menu-list li:first-child .lang-menu-item {
		border-top-left-radius: 14px;
		border-top-right-radius: 14px;
	}
	.lang-menu-list li:last-child .lang-menu-item {
		border-bottom-left-radius: 14px;
		border-bottom-right-radius: 14px;
	}
	.lang-menu-item.is-current::after {
		content: '✓';
		position: absolute;
		top: 50%;
		right: 0.46rem;
		transform: translateY(-50%);
		color: var(--accent-dark);
		font-size: 0.76rem;
		line-height: 1;
		font-weight: 700;
	}
	.lang-menu-item.is-disabled {
		cursor: not-allowed;
		color: rgb(var(--gray-dark));
		opacity: 0.7;
	}
	.lang-menu-item.is-disabled:hover {
		background: transparent;
		border-color: transparent;
	}
	.lang-menu-labels {
		display: grid;
		gap: 0.02rem;
		min-width: 0;
	}
	.lang-menu-native {
		font-size: 0.84rem;
		line-height: 1.04;
		font-weight: 700;
		white-space: nowrap;
	}
	.lang-menu-english {
		font-size: 0.62rem;
		color: rgb(var(--gray-dark));
		line-height: 1.02;
		min-height: 0.58rem;
		opacity: 0.88;
	}
	.lang-menu-english.is-placeholder {
		visibility: hidden;
	}
	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
		width: 100%;
		justify-content: flex-end;
	}
	.site-nav a {
		color: rgb(var(--black));
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		padding: 0.35rem 0.85rem;
		border-radius: 999px;
		border: 1px solid transparent;
		background: rgba(47, 111, 85, 0.08);
		transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		line-height: 1;
		white-space: nowrap;
	}
	.nav-icon {
		width: 16px;
		height: 16px;
		padding: 2px;
		box-sizing: content-box;
		stroke: currentColor;
		stroke-width: 1.6;
		fill: none;
		stroke-linecap: round;
		stroke-linejoin: round;
		color: var(--accent);
		background: rgba(47, 111, 85, 0.16);
		border-radius: 6px;
	}
	.site-nav a[aria-current="page"] {
		background: rgba(47, 111, 85, 0.22);
		border-color: rgba(47, 111, 85, 0.45);
		color: var(--accent-dark);
		box-shadow: inset 0 0 0 1px rgba(47, 111, 85, 0.2);
	}
	.site-nav a:hover {
		color: var(--accent-dark);
		background: rgba(47, 111, 85, 0.16);
		border-color: rgba(47, 111, 85, 0.25);
		transform: translateY(-1px);
	}
	.site-footer {
		border-top: 1px solid rgb(var(--stroke));
		padding: 2.5rem 1rem 3rem;
		color: rgb(var(--gray));
		background: linear-gradient(180deg, rgba(255, 250, 240, 0.8), rgba(255, 245, 230, 0.95));
	}
	.footer-inner {
		max-width: var(--content-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.site-footer p {
		margin: 0;
	}
	.footer-links {
		display: inline-flex;
		gap: 0.9rem;
		flex-wrap: wrap;
	}
	.footer-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 600;
	}
	.footer-links a:hover {
		color: var(--accent-dark);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	@media (max-width: 900px) {
		.site-bar {
			flex-direction: column;
			align-items: flex-start;
		}
		.site-top {
			grid-template-columns: 1fr;
			align-items: flex-start;
		}
		.language-picker {
			align-self: flex-end;
			justify-self: end;
		}
		.site-nav {
			width: 100%;
			justify-content: flex-start;
		}
		.site-logo {
			width: min(92vw, 500px);
			height: auto;
		}
		.lang-menu-popover {
			right: 0;
		}
	}
	@media (max-width: 560px) {
		.lang-menu-popover {
			width: min(184px, calc(100vw - 0.75rem));
		}
	}
</style>
