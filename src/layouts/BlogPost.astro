---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../components/Layout.astro';
import SeoJsonLd from '../components/SeoJsonLd.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	lang?: 'en' | 'zh';
	alternates?: { lang: string; url: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, lang = 'en', alternates } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const published = pubDate?.toISOString();
const modified = (updatedDate ?? pubDate)?.toISOString();
---

<html lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage ?? '/og-default.png'}
			type="article"
			lang={lang}
			alternates={alternates}
		/>
		{published && modified && (
			<SeoJsonLd
				title={title}
				description={description}
				url={pageUrl}
				datePublished={published}
				dateModified={modified}
				type="BlogPosting"
				image={heroImage ?? '/og-default.png'}
				inLanguage={lang}
			/>
		)}
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
				padding-bottom: 3rem;
			}
			.hero-image {
				width: 100%;
				max-width: var(--content-width);
				margin: 1.5rem auto 0;
				padding: 0 1rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 18px;
				border: 1px solid rgb(var(--stroke));
				box-shadow: var(--shadow-soft);
				background: var(--surface);
			}
			.prose {
				width: calc(100% - 2em);
				max-width: var(--content-width);
				margin: -2rem auto 0;
				padding: 2rem 2rem 2.5rem;
				color: rgb(var(--gray-dark));
				background: var(--surface);
				border: 1px solid rgb(var(--stroke));
				border-radius: 24px;
				box-shadow: var(--shadow-lift);
				position: relative;
			}
			.title {
				margin-bottom: 1.5em;
				padding: 0.5em 0 0;
				text-align: left;
				line-height: 1.1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.title hr {
				margin-top: 1.5rem;
				border-top: 1px solid rgba(47, 111, 85, 0.25);
			}
			@media (max-width: 720px) {
				.prose {
					padding: 1.5rem;
					margin-top: -1rem;
				}
				.title {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Layout>
			<main>
				<article>
					<div class="hero-image">
						{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
					</div>
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot />
					</div>
				</article>
			</main>
		</Layout>
	</body>
</html>
