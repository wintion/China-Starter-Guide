---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BlogPost.astro';
import { buildAlternates, DEFAULT_LANG, getLangFromId, normalizeLangParam } from '../../utils/i18n';

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	const langs = Array.from(new Set(guides.map((guide) => getLangFromId(guide.id))));
	return langs.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLangParam(Astro.params.lang);
if (lang === DEFAULT_LANG) {
	return Astro.redirect('/about', 301);
}
const allGuides = await getCollection('guides');
const availableLangs = Array.from(new Set(allGuides.map((guide) => getLangFromId(guide.id))));
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, availableLangs, DEFAULT_LANG);
---

<Layout
	title="About China Starter Guide"
	description="Why this guide exists and how to use it."
	pubDate={new Date('August 08 2021')}
	lang={lang}
	alternates={alternates}
>
	<p>
		China Starter Guide is a practical reference for first-time visitors. We focus on clear, step-by-step
		answers to the questions travelers actually face before and during a trip.
	</p>
	<p>
		The guide is built to reduce uncertainty: entry requirements, payments, connectivity, transport, and
		city planning are explained in plain language with actionable checklists.
	</p>
	<p>
		If you find something outdated or unclear, please report it. We update the content continuously so it
		stays useful on the ground.
	</p>
</Layout>
