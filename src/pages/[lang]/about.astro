---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Layout from '../../components/Layout.astro';
import { buildAlternates, DEFAULT_LANG, getLangFromId, normalizeLangParam } from '../../utils/i18n';
import { getAboutCopy } from '../../utils/localized-copy';

type AboutPanel = {
	title: string;
	body: string;
	items?: readonly string[];
};

type AboutCopy = {
	metaTitle: string;
	metaDescription: string;
	heroTitle: string;
	heroBody: string;
	heroLinks: string;
	panels: readonly AboutPanel[];
	disclaimerTitle: string;
	disclaimer: readonly string[];
	ctaTitle: string;
	ctaBody: string;
	ctaButton: string;
};

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	const langs = Array.from(new Set(guides.map((guide) => getLangFromId(guide.id))));
	return langs.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLangParam(Astro.params.lang);
if (lang === DEFAULT_LANG) {
	return Astro.redirect('/about', 301);
}

const allGuides = await getCollection('guides');
const availableLangs = Array.from(new Set(allGuides.map((guide) => getLangFromId(guide.id))));
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, availableLangs);
const contactUrl = 'mailto:contact@chinastarterguide.com';
const aboutCopy = getAboutCopy(lang) as unknown as AboutCopy;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<BaseHead
			title={aboutCopy.metaTitle}
			description={aboutCopy.metaDescription}
			lang={lang}
			alternates={alternates}
		/>
		<style>
			.page {
				display: grid;
				gap: 2.5rem;
			}
			.hero {
				padding: 2.5rem;
				border: 1px solid rgb(var(--stroke));
				border-radius: 24px;
				background: var(--surface);
				box-shadow: var(--shadow-soft);
				position: relative;
				overflow: hidden;
			}
			.hero::before {
				content: "";
				position: absolute;
				inset: 0;
				background:
					radial-gradient(360px 220px at 12% 0%, rgba(47, 111, 85, 0.2), transparent 70%),
					radial-gradient(320px 220px at 92% 20%, rgba(198, 64, 43, 0.18), transparent 60%);
				opacity: 0.9;
				pointer-events: none;
			}
			.hero > * {
				position: relative;
			}
			.hero h1 {
				margin-bottom: 0.75rem;
				font-size: 2.6rem;
			}
			.hero p {
				max-width: 720px;
				color: rgb(var(--gray-dark));
			}
			.section-grid {
				display: grid;
				gap: 1.5rem;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			}
			.panel {
				border: 1px solid rgb(var(--stroke));
				border-radius: 20px;
				padding: 1.5rem;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 249, 240, 0.92));
				box-shadow: 0 10px 18px rgba(46, 34, 20, 0.08);
			}
			.panel h2 {
				margin-top: 0;
				margin-bottom: 0.6rem;
				font-size: 1.4rem;
			}
			.panel ul {
				margin: 0.6rem 0 0;
				padding-inline-start: 1.1rem;
			}
			.panel li {
				margin: 0.35rem 0;
			}
			.disclaimer {
				border: 1px solid rgba(198, 64, 43, 0.35);
				background: rgba(255, 248, 240, 0.9);
				border-radius: 20px;
				padding: 1.6rem;
				box-shadow: 0 10px 16px rgba(46, 34, 20, 0.08);
			}
			.disclaimer h2 {
				margin-top: 0;
				color: var(--accent-warm);
			}
			.disclaimer p {
				margin: 0.6rem 0;
				color: rgb(var(--gray-dark));
			}
			.cta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1.5rem 1.8rem;
				border-radius: 20px;
				background: rgba(47, 111, 85, 0.12);
				border: 1px solid rgba(47, 111, 85, 0.3);
			}
			.cta a {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.55rem 1.2rem;
				border-radius: 999px;
				background: var(--accent);
				color: white;
				text-decoration: none;
				font-weight: 600;
			}
			.cta a:hover {
				background: var(--accent-dark);
			}
			@media (max-width: 720px) {
				.hero {
					padding: 1.8rem;
				}
				.hero h1 {
					font-size: 2.1rem;
				}
			}
		</style>
	</head>
	<body>
		<Layout>
			<main class="page">
				<section class="hero">
					<h1>{aboutCopy.heroTitle}</h1>
					<p>{aboutCopy.heroBody}</p>
					<p>{aboutCopy.heroLinks}</p>
				</section>

				<section class="section-grid">
					{aboutCopy.panels.map((panel: AboutPanel) => (
						<article class="panel">
							<h2>{panel.title}</h2>
							<p>{panel.body}</p>
							{panel.items && (
								<ul>
									{panel.items.map((item: string) => (
										<li>{item}</li>
									))}
								</ul>
							)}
						</article>
					))}
				</section>

				<section class="disclaimer">
					<h2>{aboutCopy.disclaimerTitle}</h2>
					{aboutCopy.disclaimer.map((paragraph: string) => (
						<p>{paragraph}</p>
					))}
				</section>

				<section class="cta">
					<div>
						<strong>{aboutCopy.ctaTitle}</strong>
						<span>{aboutCopy.ctaBody}</span>
					</div>
					<a href={contactUrl}>{aboutCopy.ctaButton}</a>
				</section>
			</main>
		</Layout>
	</body>
</html>
