---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Layout from '../../../components/Layout.astro';
import { SITE_TITLE } from '../../../consts';
import {
	buildAlternates,
	DEFAULT_LANG,
	getLangFromId,
	normalizeLangParam,
	stripLangFromId,
	withOptionalLangPrefix,
} from '../../../utils/i18n';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const langs = Array.from(new Set(posts.map((post) => getLangFromId(post.id))));
	return langs.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLangParam(Astro.params.lang);
if (lang === DEFAULT_LANG) {
	return Astro.redirect('/blog', 301);
}
const allPosts = await getCollection('blog');
const availableLangs = Array.from(new Set(allPosts.map((post) => getLangFromId(post.id))));
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, availableLangs);

const posts = allPosts
	.filter((post) => getLangFromId(post.id) === lang)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const withLang = (path: string) => withOptionalLangPrefix(path, lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={`Blog | ${SITE_TITLE}`}
			description="Updates and stories that help first-time visitors plan a smooth trip to China."
			lang={lang}
			alternates={alternates}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: var(--content-width);
				margin: 0 auto;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
				border: 1px solid rgb(var(--stroke));
				border-radius: 18px;
				padding: 1rem;
				background: var(--surface);
				box-shadow: var(--shadow-soft);
				transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
			}
			ul li:hover {
				transform: translateY(-2px);
				border-color: rgba(47, 111, 85, 0.35);
				box-shadow: var(--shadow-lift);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: left;
				padding: 1.5rem;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 16px;
				border: 1px solid rgb(var(--stroke));
				background: var(--surface-strong);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent-warm);
			}
			ul a:hover img {
				box-shadow: var(--shadow-soft);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: left;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Layout>
			<main>
				<section>
					<ul>
						{
							posts.map((post) => (
								<li>
									<a href={withLang(`/${stripLangFromId(post.id)}`)}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))
						}
					</ul>
				</section>
			</main>
		</Layout>
	</body>
</html>
