---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FeaturedEntryPoints from '../../components/FeaturedEntryPoints.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../components/Layout.astro';
import {
	buildAlternates,
	DEFAULT_LANG,
	getLangFromId,
	normalizeLangParam,
	stripLangFromId,
	withOptionalLangPrefix,
} from '../../utils/i18n';
import { getCategoryLabel, getHomeCopy, type CategorySlug } from '../../utils/localized-copy';

type LinkCard = {
	path: string;
	title: string;
	description: string;
};

type HomeCopy = {
	metaTitle: string;
	metaDescription: string;
	heroTitle: string;
	heroDescription: string;
	primaryCtas: readonly LinkCard[];
	sections: {
		featured: string;
		topConcerns: string;
		medicalBasics: string;
		medicalIntro: string;
		recent: string;
		lastUpdated: string;
	};
	topConcernIds: readonly string[];
	medicalBasicIds: readonly string[];
};

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	const langs = Array.from(new Set(guides.map((guide) => getLangFromId(guide.id))));
	return langs.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLangParam(Astro.params.lang);
if (lang === DEFAULT_LANG) {
	return Astro.redirect('/', 301);
}
const allGuides = await getCollection('guides');
const availableLangs = Array.from(new Set(allGuides.map((guide) => getLangFromId(guide.id))));
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, availableLangs);

const guides = allGuides
	.filter((guide) => getLangFromId(guide.id) === lang)
	.sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());

const recentGuides = guides.slice(0, 6);
const homeCopy = getHomeCopy(lang) as unknown as HomeCopy;
const guideById = new Map(
	guides.map((guide) => [stripLangFromId(guide.id).replace(/^guides\//, ''), guide]),
);
const topConcerns = homeCopy.topConcernIds
	.map((id) => guideById.get(id))
	.filter((guide): guide is (typeof guides)[number] => Boolean(guide));
const medicalBasics = homeCopy.medicalBasicIds
	.map((id) => guideById.get(id))
	.filter((guide): guide is (typeof guides)[number] => Boolean(guide));
const formatCategory = (value: string) => getCategoryLabel(value as CategorySlug, lang);
const withLang = (path: string) => withOptionalLangPrefix(path, lang);
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<BaseHead
			title={homeCopy.metaTitle}
			description={homeCopy.metaDescription}
			lang={lang}
			alternates={alternates}
		/>
		<style>
			.hero {
				padding: 2.5rem;
				border: 1px solid rgb(var(--stroke));
				border-radius: 24px;
				background: var(--surface);
				box-shadow: var(--shadow-soft);
				position: relative;
				overflow: hidden;
			}
			.hero::before {
				content: "";
				position: absolute;
				inset: 0;
				background:
					radial-gradient(360px 200px at 10% 0%, rgba(47, 111, 85, 0.2), transparent 70%),
					radial-gradient(320px 220px at 92% 18%, rgba(198, 64, 43, 0.18), transparent 60%);
				opacity: 0.9;
				pointer-events: none;
			}
			.hero > * {
				position: relative;
			}
			.hero h1 {
				font-size: 3rem;
				margin-bottom: 0.8rem;
			}
			.hero p {
				max-width: 680px;
				color: rgb(var(--gray-dark));
			}
			.section {
				margin-top: 3.25rem;
			}
			.section > h2 {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 1rem;
			}
			.section > h2::before {
				content: "";
				width: 28px;
				height: 6px;
				border-radius: 999px;
				background: var(--accent);
				box-shadow: 0 4px 10px rgba(47, 111, 85, 0.25);
			}
			.card-grid {
				display: grid;
				gap: 1.25rem;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				margin-top: 1.5rem;
			}
			.card {
				display: block;
				border: 1px solid rgb(var(--stroke));
				border-radius: 18px;
				padding: 1rem;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 249, 240, 0.95));
				box-shadow: 0 10px 18px rgba(46, 34, 20, 0.08);
				text-decoration: none;
				color: rgb(var(--black));
				transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.card strong {
				display: block;
				font-size: 1.05rem;
			}
			.card:hover {
				border-color: rgba(47, 111, 85, 0.35);
				box-shadow: var(--shadow-lift);
				transform: translateY(-2px);
			}
			.card p {
				margin: 0.4rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.section-intro {
				max-width: 720px;
				margin: 0 0 1.25rem;
				color: rgb(var(--gray-dark));
			}
			.list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}
			.list li {
				border: 1px solid rgb(var(--stroke));
				border-radius: 16px;
				padding: 1rem 1.1rem;
				background: var(--surface);
				box-shadow: 0 8px 16px rgba(46, 34, 20, 0.08);
				transition: transform 0.2s ease, border-color 0.2s ease;
			}
			.list li:hover {
				transform: translateY(-2px);
				border-color: rgba(47, 111, 85, 0.35);
			}
			.list a {
				text-decoration: underline;
				text-decoration-thickness: 1.5px;
				text-underline-offset: 0.18em;
				color: var(--accent-dark);
			}
			.list a:hover {
				color: var(--accent-warm);
			}
			.list p:not(.meta) {
				margin: 0.35rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.meta {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-top: 0.25rem;
			}
			@media (max-width: 720px) {
				.hero {
					padding: 1.75rem;
				}
				.hero h1 {
					font-size: 2.4rem;
				}
				.section > h2 {
					font-size: 1.8rem;
				}
			}
		</style>
	</head>
	<body>
		<Layout>
			<main>
				<section class="hero">
					<h1>{homeCopy.heroTitle}</h1>
					<p>{homeCopy.heroDescription}</p>
					<div class="card-grid">
						{homeCopy.primaryCtas.map((cta: LinkCard) => (
							<a class="card" href={withLang(cta.path)}>
								<strong>{cta.title}</strong>
								<p>{cta.description}</p>
							</a>
						))}
					</div>
				</section>

				<div class="section">
					<h2>{homeCopy.sections.featured}</h2>
					<FeaturedEntryPoints />
				</div>

				<section class="section">
					<h2>{homeCopy.sections.topConcerns}</h2>
					<ul class="list">
						{topConcerns.map((guide) => (
							<li>
								<a href={withLang(`/${stripLangFromId(guide.id)}`)}>{guide.data.title}</a>
								<p>{guide.data.description}</p>
							</li>
						))}
					</ul>
				</section>

				<section class="section">
					<h2>{homeCopy.sections.medicalBasics}</h2>
					<p class="section-intro">{homeCopy.sections.medicalIntro}</p>
					<div class="card-grid">
						{medicalBasics.map((guide) => (
							<a class="card" href={withLang(`/${stripLangFromId(guide.id)}`)}>
								<strong>{guide.data.title}</strong>
								<p>{guide.data.description}</p>
							</a>
						))}
					</div>
				</section>

				<section class="section">
					<h2>{homeCopy.sections.recent}</h2>
					<ul class="list">
						{recentGuides.map((guide) => {
							const guidePath = `/${stripLangFromId(guide.id)}`;
							return (
								<li>
									<a href={withLang(guidePath)}>{guide.data.title}</a>
									<p>{guide.data.description}</p>
									<p class="meta">
										{formatCategory(guide.data.category)} · {homeCopy.sections.lastUpdated}
										<FormattedDate date={guide.data.lastUpdated} />
									</p>
								</li>
							);
						})}
					</ul>
				</section>
			</main>
		</Layout>
	</body>
</html>
