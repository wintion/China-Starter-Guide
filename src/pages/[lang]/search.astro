---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Layout from '../../components/Layout.astro';
import { buildAlternates, DEFAULT_LANG, getLangFromId, normalizeLangParam } from '../../utils/i18n';
import { getSearchCopy } from '../../utils/localized-copy';

const isProd = import.meta.env.PROD;
export async function getStaticPaths() {
	const guides = await getCollection('guides');
	const langs = Array.from(new Set(guides.map((guide) => getLangFromId(guide.id))));
	return langs.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLangParam(Astro.params.lang);
if (lang === DEFAULT_LANG) {
	return Astro.redirect('/search', 301);
}
const allGuides = await getCollection('guides');
const availableLangs = Array.from(new Set(allGuides.map((guide) => getLangFromId(guide.id))));
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, availableLangs);
const searchCopy = getSearchCopy(lang);
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<BaseHead
			title={searchCopy.metaTitle}
			description={searchCopy.metaDescription}
			lang={lang}
			alternates={alternates}
		/>
		<link rel="preload" href="/pagefind/pagefind.js" as="script" />
		<link rel="preload" href="/pagefind/pagefind.wasm" as="fetch" type="application/wasm" crossorigin />
		<style>
			.search-shell {
				max-width: var(--content-width);
				background: var(--surface);
				border: 1px solid rgb(var(--stroke));
				border-radius: 24px;
				padding: 2rem;
				box-shadow: var(--shadow-soft);
			}
			.search-input {
				width: 100%;
				max-width: 480px;
				padding: 0.75rem 0.9rem;
				border: 1px solid rgb(var(--stroke));
				border-radius: 14px;
				font-size: 1rem;
				background: var(--surface-strong);
			}
			.search-input:focus {
				outline: 2px solid rgba(47, 111, 85, 0.25);
				outline-offset: 2px;
			}
			.search-status {
				color: rgb(var(--gray));
				margin-top: 0.75rem;
			}
			.search-results {
				list-style: none;
				padding: 0;
				margin: 1.5rem 0 0;
				display: grid;
				gap: 1rem;
			}
			.search-results li {
				border: 1px solid rgb(var(--stroke));
				border-radius: 16px;
				padding: 1rem 1.1rem;
				background: var(--surface);
				box-shadow: 0 8px 16px rgba(46, 34, 20, 0.08);
				transition: transform 0.2s ease, border-color 0.2s ease;
			}
			.search-results li:hover {
				transform: translateY(-2px);
				border-color: rgba(47, 111, 85, 0.35);
			}
			.search-results a {
				text-decoration: underline;
				text-decoration-thickness: 1.5px;
				text-underline-offset: 0.18em;
				color: var(--accent-dark);
				font-weight: 600;
			}
			.search-results a:hover {
				color: var(--accent-warm);
			}
			.search-snippet {
				margin: 0.4rem 0 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Layout>
			<main>
				<section class="search-shell">
					<h1>{searchCopy.title}</h1>
					<p>{searchCopy.intro}</p>
					<label class="sr-only" for="search-input">{searchCopy.label}</label>
					<input
						id="search-input"
						class="search-input"
						type="search"
						placeholder={searchCopy.placeholder}
						autocomplete="off"
					/>
					<p id="search-status" class="search-status">{searchCopy.startTyping}</p>
					<ul id="search-results" class="search-results"></ul>
				</section>
			</main>
		</Layout>
		<script define:vars={{ isProd, searchCopy }}>
			const input = document.querySelector('#search-input');
			const results = document.querySelector('#search-results');
			const status = document.querySelector('#search-status');
			let pagefindPromise;

			const renderStatus = (message) => {
				status.textContent = message;
			};

			const loadPagefind = () => {
				if (pagefindPromise) {
					return pagefindPromise;
				}
				pagefindPromise = import('/pagefind/pagefind.js').then((module) => {
					if (module && typeof module.search === 'function') {
						return module;
					}
					throw new Error('Pagefind failed to load');
				});
				return pagefindPromise;
			};

			const renderResults = (items) => {
				if (!items.length) {
					results.innerHTML = '';
					renderStatus(searchCopy.noResults);
					return;
				}

				results.innerHTML = items
					.map((item) => {
						const title = item.meta?.title || item.meta?.heading || item.url;
						const snippet = item.excerpt || '';
						return `
							<li>
								<a href="${item.url}">${title}</a>
								<p class="search-snippet">${snippet}</p>
							</li>
						`;
					})
					.join('');
				renderStatus(searchCopy.resultsLabel.replace('{count}', String(items.length)));
			};

			const initializeSearch = async () => {
				if (!isProd) {
					input.disabled = true;
					renderStatus(searchCopy.availableAfterBuild);
					return;
				}
				input.disabled = true;
				renderStatus(searchCopy.loadingIndex);
				try {
					await loadPagefind();
					input.disabled = false;
					renderStatus(searchCopy.startTyping);
				} catch (error) {
					input.disabled = true;
					renderStatus(searchCopy.temporarilyUnavailable);
				}
			};

			const runSearch = async (pagefind, query) => {
				if (typeof pagefind.debouncedSearch === 'function') {
					return pagefind.debouncedSearch(query, {}, 250);
				}
				return pagefind.search(query);
			};

			input.addEventListener('input', async (event) => {
				const query = event.target.value.trim();

				if (!query) {
					results.innerHTML = '';
					renderStatus(searchCopy.startTyping);
					return;
				}

				try {
					const pagefind = await loadPagefind();
					renderStatus(searchCopy.searching);
					const search = await runSearch(pagefind, query);
					if (!search) {
						return;
					}
					const data = await Promise.all(search.results.map((result) => result.data()));
					renderResults(data);
				} catch (error) {
					results.innerHTML = '';
					renderStatus(searchCopy.stillLoading);
				}
			});

			initializeSearch();
		</script>
	</body>
</html>
