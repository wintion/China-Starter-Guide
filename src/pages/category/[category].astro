---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../components/Layout.astro';
import {
	buildAlternates,
	DEFAULT_LANG,
	getLangFromId,
	stripLangFromId,
	withOptionalLangPrefix,
} from '../../utils/i18n';

export const categories = ['prepare', 'payment', 'transport', 'life', 'medical', 'cities', 'tips'] as const;

export async function getStaticPaths() {
	const allGuides = await getCollection('guides');
	const enGuides = allGuides.filter((guide) => getLangFromId(guide.id) === DEFAULT_LANG);
	const categorySet = new Set(enGuides.map((guide) => guide.data.category));
	return categories
		.filter((category) => categorySet.has(category))
		.map((category) => ({
			params: { category },
		}));
}

const lang = DEFAULT_LANG;
const { category } = Astro.params;

if (!category || !categories.includes(category)) {
	return new Response(null, { status: 404 });
}

const allGuides = await getCollection('guides');
const categoryLangs = Array.from(
	new Set(
		allGuides.filter((entry) => entry.data.category === category).map((entry) => getLangFromId(entry.id)),
	),
);
const alternates = buildAlternates(Astro.url.pathname, Astro.site ?? Astro.url, categoryLangs, lang);

const guides = allGuides
	.filter((entry) => getLangFromId(entry.id) === lang)
	.filter((entry) => entry.data.category === category)
	.sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());

type CategoryConfig = {
	intro: string;
	support?: string;
	featuredIds?: string[];
	quickPaths?: { title: string; description: string; id: string }[];
	topicGroups?: { title: string; ids: string[] }[];
};

const categoryConfig: Record<string, CategoryConfig> = {
	prepare: {
		intro: 'Visa, entry, safety, and pre-trip essentials to get you ready.',
		featuredIds: [
			'prepare/is-china-safe',
			'prepare/visa-free-explained',
			'prepare/visa-needed-checklist',
			'prepare/entry-documents',
			'prepare/return-ticket-proof',
			'prepare/internet-restrictions-overview',
		],
	},
	payment: {
		intro: 'Mobile wallets, cards, cash, and QR payments that actually work.',
		featuredIds: [
			'payment/how-to-pay-in-china',
			'payment/qr-code-payment-basics',
			'payment/alipay-for-foreigners',
			'payment/wechat-pay-for-foreigners',
			'payment/link-foreign-card',
			'payment/cash-in-china',
		],
	},
	transport: {
		intro: 'Trains, metros, flights, and airport transfers with clear steps.',
		featuredIds: [
			'transport/airport-to-city',
			'transport/metro-basics',
			'transport/using-didi',
			'transport/high-speed-rail-basics',
			'transport/buying-train-tickets',
			'transport/travel-between-cities',
		],
	},
	life: {
		intro: 'Everyday living basics: SIMs, hotels, food, apps, and connectivity.',
		featuredIds: [
			'life/sim-card-vs-esim',
			'life/buying-sim-at-airport',
			'life/hotel-checkin-what-to-expect',
			'life/hotel-foreigners-policy',
			'life/translation-apps',
			'life/wifi-public-internet',
		],
	},
	medical: {
		intro: 'How foreigners can use clinics, hospitals, pharmacies, and emergency care in China with less stress.',
		support:
			'Start here if you want clear, practical help choosing the right medical path in China before a small problem turns into a confusing one.',
		featuredIds: [
			'medical/see-a-doctor-in-china',
			'medical/public-hospitals-vs-private-clinics',
			'medical/emergency-care-in-china',
			'medical/medical-costs-in-china',
			'medical/how-pharmacies-work-in-china',
			'medical/health-insurance-for-foreign-visitors',
		],
		quickPaths: [
			{
				title: 'I need care now',
				description: 'Choose between pharmacy, clinic, hospital, or emergency care quickly.',
				id: 'medical/see-a-doctor-in-china',
			},
			{
				title: 'I need the right hospital',
				description: 'Decide between public hospitals, private clinics, and international departments.',
				id: 'medical/choosing-a-hospital-in-china',
			},
			{
				title: 'I need urgent help',
				description: 'Use this path when symptoms are escalating and the trip cannot wait.',
				id: 'medical/emergency-care-in-china',
			},
		],
		topicGroups: [
			{
				title: 'Start here',
				ids: ['medical/see-a-doctor-in-china', 'medical/public-hospitals-vs-private-clinics'],
			},
			{
				title: 'Appointments and access',
				ids: [
					'medical/booking-hospital-appointments-in-china',
					'medical/choosing-a-hospital-in-china',
					'medical/international-departments-in-chinese-hospitals',
				],
			},
			{
				title: 'Costs and coverage',
				ids: ['medical/medical-costs-in-china', 'medical/health-insurance-for-foreign-visitors'],
			},
			{
				title: 'Pharmacy and medicines',
				ids: [
					'medical/how-pharmacies-work-in-china',
					'medical/prescription-refills-in-china',
					'medical/bringing-medicines-vs-buying-locally',
				],
			},
			{
				title: 'Urgent help',
				ids: ['medical/emergency-care-in-china', 'medical/getting-sick-on-a-short-trip-in-china'],
			},
		],
	},
	cities: {
		intro: 'Choose the right cities, routes, and seasons for a first trip.',
		featuredIds: [
			'cities/best-cities-first-time',
			'cities/how-much-time-in-china',
			'cities/how-many-cities-to-visit',
			'cities/suggested-routes-7-days',
			'cities/suggested-routes-14-days',
			'cities/beijing-first-timers',
		],
	},
	tips: {
		intro: 'Short, practical tips that reduce friction: etiquette, safety, communication, and daily habits.',
		featuredIds: [
			'tips/common-mistakes-first-timers',
			'tips/cultural-do-and-dont',
			'tips/greetings-and-social-norms',
			'tips/what-to-wear',
			'tips/dealing-with-crowds',
			'tips/traveling-at-night',
		],
		topicGroups: [
			{
				title: 'Etiquette and social norms',
				ids: [
					'tips/greetings-and-social-norms',
					'tips/compliments-and-politeness',
					'tips/gestures-to-avoid',
					'tips/public-affection',
					'tips/cultural-do-and-dont',
				],
			},
			{
				title: 'Communication and understanding',
				ids: [
					'tips/handling-misunderstandings',
					'tips/staying-connected-without-english',
					'tips/taking-photos-privacy',
				],
			},
			{
				title: 'Safety and awareness',
				ids: ['tips/dealing-with-crowds', 'tips/traveling-at-night', 'tips/safety-with-electronics'],
			},
			{
				title: 'Families and seniors',
				ids: ['tips/family-travel-tips', 'tips/seniors-travel-tips'],
			},
			{
				title: 'Shopping and bargaining',
				ids: ['tips/bargaining-basics'],
			},
		],
	},
};

const config = categoryConfig[category] ?? {
	intro: 'Focused, practical guidance for first-time visitors.',
};

const guideById = new Map(
	guides.map((guide) => [stripLangFromId(guide.id).replace(/^guides\//, ''), guide]),
);
const pickGuides = (ids: string[]) =>
	ids.map((id) => guideById.get(id)).filter((entry): entry is CollectionEntry<'guides'> => Boolean(entry));
const quickPaths = (config.quickPaths ?? [])
	.map((item) => ({ ...item, entry: guideById.get(item.id) }))
	.filter((item): item is typeof item & { entry: CollectionEntry<'guides'> } => Boolean(item.entry));
const featuredGuides = config.featuredIds ? pickGuides(config.featuredIds) : guides.slice(0, 6);

const tagLabelOverrides: Record<string, string> = {
	alipay: 'Alipay',
	'wechat-pay': 'WeChat Pay',
	wechat: 'WeChat',
	'qr-code': 'QR code',
	qr: 'QR',
	esim: 'eSIM',
	sim: 'SIM',
	vpn: 'VPN',
	wifi: 'Wi-Fi',
	'12306': '12306',
};

const formatTagLabel = (value: string) =>
	tagLabelOverrides[value] ??
	value
		.split('-')
		.map((word) => (word ? `${word.charAt(0).toUpperCase()}${word.slice(1)}` : ''))
		.join(' ');

const tagTopics = (() => {
	const tagMap = new Map<string, CollectionEntry<'guides'>[]>();
	for (const guide of guides) {
		for (const tag of guide.data.tags ?? []) {
			const list = tagMap.get(tag) ?? [];
			list.push(guide);
			tagMap.set(tag, list);
		}
	}
	const entries = Array.from(tagMap.entries()).sort(
		(a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]),
	);
	if (entries.length === 0) return [];
	const primary = entries.filter(([, list]) => list.length >= 2);
	const chosen = (primary.length > 0 ? primary : entries).slice(0, 6);
	return chosen.map(([tag, list]) => ({
		title: formatTagLabel(tag),
		entries: list.slice(0, 4),
	}));
})();

const topics = config.topicGroups
	? config.topicGroups
			.map((topic) => ({ title: topic.title, entries: pickGuides(topic.ids) }))
			.filter((topic) => topic.entries.length > 0)
	: tagTopics;

const label = `${category.charAt(0).toUpperCase()}${category.slice(1)}`;
const lowerLabel = label.toLowerCase();
const introCopy = config.intro;
const supportCopy = config.support;
const featuredHeading = category === 'tips' ? 'Featured tips' : `Featured ${lowerLabel} guides`;
const allHeading = category === 'tips' ? 'All tips' : `All ${lowerLabel} guides`;
const withLang = (path: string) => withOptionalLangPrefix(path, lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={`${label} guides | China Starter Guide`}
			description={`Practical ${label.toLowerCase()} guides for first-time visitors to China.`}
			lang={lang}
			alternates={alternates}
		/>
		<style>
			.category-header {
				margin-bottom: 2.5rem;
				padding: 2rem;
				border-radius: 24px;
				background: var(--surface);
				border: 1px solid rgb(var(--stroke));
				box-shadow: var(--shadow-soft);
				position: relative;
				overflow: hidden;
			}
			.category-header::after {
				content: "";
				position: absolute;
				inset: 0;
				background-image: var(--category-pattern);
				background-repeat: no-repeat;
				background-position: right 12px center;
				background-size: 520px auto;
				opacity: 0.55;
				pointer-events: none;
			}
			.category-header > * {
				position: relative;
				z-index: 1;
			}
			.category-header[data-category="prepare"] {
				--category-pattern: url("/category-bg-prepare.svg");
			}
			.category-header[data-category="payment"] {
				--category-pattern: url("/category-bg-payment.svg");
			}
			.category-header[data-category="transport"] {
				--category-pattern: url("/category-bg-transport.svg");
			}
			.category-header[data-category="life"] {
				--category-pattern: url("/category-bg-life.svg");
			}
			.category-header[data-category="medical"] {
				--category-pattern: url("/category-bg-medical.svg");
			}
			.category-header[data-category="cities"] {
				--category-pattern: url("/category-bg-cities.svg");
			}
			.category-header[data-category="tips"] {
				--category-pattern: url("/category-bg-tips.svg");
			}
			.category-count {
				margin-top: 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.category-support {
				max-width: 720px;
				margin: 0.85rem 0 0;
				color: rgb(var(--gray-dark));
			}
			.category-section {
				margin-bottom: 2.5rem;
			}
			.category-section h2,
			#all-guides {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 1rem;
			}
			.category-section h2::before,
			#all-guides::before {
				content: "";
				width: 28px;
				height: 6px;
				border-radius: 999px;
				background: var(--accent);
				box-shadow: 0 4px 10px rgba(47, 111, 85, 0.25);
			}
			.featured-grid {
				display: grid;
				gap: 1.25rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.featured-card {
				display: grid;
				gap: 0.7rem;
				align-content: start;
				min-height: 200px;
				border: 1px solid rgb(var(--stroke));
				border-radius: 20px;
				padding: 1.1rem;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 249, 240, 0.96));
				box-shadow: 0 10px 18px rgba(46, 34, 20, 0.08);
				text-decoration: none;
				color: rgb(var(--black));
				transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
				position: relative;
				overflow: hidden;
			}
			.featured-card::after {
				content: "";
				position: absolute;
				inset: auto -14px -26px auto;
				width: 92px;
				height: 92px;
				border-radius: 999px;
				background: radial-gradient(circle, rgba(47, 111, 85, 0.1), transparent 70%);
				pointer-events: none;
			}
			.featured-card[data-category="medical"] {
				background:
					linear-gradient(180deg, rgba(245, 251, 247, 0.96), rgba(255, 249, 241, 0.98)),
					radial-gradient(circle at top right, rgba(47, 111, 85, 0.12), transparent 48%);
				border-color: rgba(47, 111, 85, 0.2);
			}
			.featured-card:hover {
				border-color: rgba(47, 111, 85, 0.35);
				box-shadow: var(--shadow-lift);
				transform: translateY(-2px);
			}
			.featured-card[data-category="medical"]:hover {
				border-color: rgba(47, 111, 85, 0.4);
			}
			.featured-card,
			.featured-card * {
				text-decoration: none;
			}
			.featured-card-eyebrow {
				display: inline-flex;
				width: fit-content;
				padding: 0.24rem 0.58rem;
				border-radius: 999px;
				background: rgba(47, 111, 85, 0.1);
				color: var(--accent-dark);
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			.featured-card p {
				margin: 0;
				line-height: 1.45;
				color: rgb(var(--gray-dark));
			}
			.featured-card strong {
				display: block;
				font-size: 1.1rem;
				line-height: 1.25;
				font-weight: 700;
			}
			.featured-card-action {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				margin-top: auto;
				color: var(--accent-dark);
				font-size: 0.9rem;
				font-weight: 700;
			}
			.featured-card-action::after {
				content: "->";
				font-size: 0.9rem;
			}
			.quick-path-grid {
				display: grid;
				gap: 1.25rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.quick-path-card {
				display: grid;
				gap: 0.85rem;
				align-content: start;
				min-height: 220px;
				border: 1px solid rgba(47, 111, 85, 0.22);
				border-radius: 22px;
				padding: 1.2rem 1.2rem 1.15rem;
				background:
					linear-gradient(180deg, rgba(243, 250, 246, 0.96), rgba(255, 250, 243, 0.98)),
					radial-gradient(circle at top right, rgba(47, 111, 85, 0.12), transparent 45%);
				box-shadow: 0 12px 22px rgba(46, 34, 20, 0.08);
				text-decoration: none;
				color: rgb(var(--black));
				transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
				position: relative;
				overflow: hidden;
			}
			.quick-path-card::after {
				content: "";
				position: absolute;
				inset: auto -18px -28px auto;
				width: 110px;
				height: 110px;
				border-radius: 999px;
				background: radial-gradient(circle, rgba(198, 64, 43, 0.12), transparent 68%);
				pointer-events: none;
			}
			.quick-path-card:hover {
				transform: translateY(-2px);
				border-color: rgba(47, 111, 85, 0.42);
				box-shadow: var(--shadow-lift);
			}
			.quick-path-card,
			.quick-path-card * {
				text-decoration: none;
			}
			.quick-path-label {
				display: inline-flex;
				width: fit-content;
				padding: 0.26rem 0.62rem;
				border-radius: 999px;
				background: rgba(47, 111, 85, 0.14);
				color: var(--accent-dark);
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0.04em;
				text-transform: uppercase;
			}
			.quick-path-card strong {
				display: block;
				font-size: 1.18rem;
				line-height: 1.2;
				color: rgb(var(--black));
			}
			.quick-path-card p {
				margin: 0;
				font-size: 0.98rem;
				line-height: 1.45;
				color: rgb(var(--gray-dark));
			}
			.quick-path-action {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				margin-top: auto;
				color: var(--accent-dark);
				font-size: 0.9rem;
				font-weight: 700;
			}
			.quick-path-action::after {
				content: "->";
				font-size: 0.9rem;
			}
			.topic-grid {
				display: grid;
				gap: 1.25rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.topic-intro {
				margin: 0 0 1rem;
				max-width: 60ch;
				color: rgb(var(--gray-dark));
			}
			.topic-card {
				border: 1px solid rgb(var(--stroke));
				border-radius: 18px;
				padding: 1.1rem;
				background: var(--surface);
				box-shadow: 0 10px 18px rgba(46, 34, 20, 0.08);
			}
			.topic-card-header {
				display: grid;
				gap: 0.3rem;
				margin-bottom: 0.9rem;
			}
			.topic-card h3 {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 700;
			}
			.topic-card ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.55rem;
			}
			.topic-card li {
				border-radius: 10px;
			}
			.topic-card li a {
				display: block;
				padding: 0.7rem 0.8rem 0.7rem 1.6rem;
				border-radius: 14px;
				position: relative;
			}
			.topic-card li a::before {
				content: "";
				position: absolute;
				left: 0.8rem;
				top: 1.1rem;
				width: 6px;
				height: 6px;
				border-radius: 999px;
				background: rgba(47, 111, 85, 0.5);
			}
			.topic-card li a:hover {
				background: rgba(47, 111, 85, 0.06);
			}
			.topic-card li a {
				text-decoration: none;
				color: var(--accent-dark);
				font-weight: 500;
			}
			.topic-card li a:hover {
				color: var(--accent-warm);
			}
			.topic-grid[data-category="medical"] .topic-card {
				padding: 1.2rem;
				border-color: rgba(47, 111, 85, 0.16);
				background:
					linear-gradient(180deg, rgba(241, 248, 244, 0.96) 0%, rgba(255, 255, 255, 0.96) 100%);
				box-shadow: 0 18px 32px rgba(46, 34, 20, 0.08);
			}
			.topic-grid[data-category="medical"] .topic-card-header {
				padding-bottom: 0.9rem;
				border-bottom: 1px solid rgba(47, 111, 85, 0.12);
			}
			.topic-grid[data-category="medical"] .topic-card li a {
				background: rgba(255, 255, 255, 0.72);
				border: 1px solid rgba(47, 111, 85, 0.08);
				box-shadow: 0 8px 16px rgba(46, 34, 20, 0.04);
			}
			.topic-grid[data-category="medical"] .topic-card li a:hover {
				background: rgba(47, 111, 85, 0.08);
			}
			.topic-grid[data-category="medical"] .topic-card li a:hover {
				transform: translateY(-1px);
				border-color: rgba(47, 111, 85, 0.18);
			}
			.category-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1.1rem;
			}
			.category-list li {
				border: 1px solid rgb(var(--stroke));
				border-radius: 18px;
				padding: 1.1rem 1.2rem;
				background: var(--surface);
				box-shadow: 0 10px 18px rgba(46, 34, 20, 0.08);
				transition: transform 0.2s ease, border-color 0.2s ease;
			}
			.category-list li:hover {
				transform: translateY(-2px);
				border-color: rgba(47, 111, 85, 0.35);
			}
			.category-list a {
				text-decoration: underline;
				text-decoration-thickness: 1.5px;
				text-underline-offset: 0.18em;
				color: var(--accent-dark);
			}
			.category-list a:hover {
				color: var(--accent-warm);
			}
			.category-meta {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin-top: 0.35rem;
			}
			@media (max-width: 980px) {
				.featured-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
				.quick-path-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
				.topic-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}
			@media (max-width: 640px) {
				.featured-grid {
					grid-template-columns: 1fr;
				}
				.quick-path-grid {
					grid-template-columns: 1fr;
				}
				.topic-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Layout>
			<main>
				<header class="category-header" data-category={category}>
					<h1>{label} guides</h1>
					<p>{introCopy}</p>
					{supportCopy && <p class="category-support">{supportCopy}</p>}
					{guides.length > 0 && <p class="category-count">{guides.length} guides available</p>}
				</header>
				{quickPaths.length > 0 && (
					<section class="category-section" aria-labelledby="quick-paths">
						<h2 id="quick-paths">Quick paths</h2>
						<div class="quick-path-grid">
								{quickPaths.map((item) => (
									<a class="quick-path-card" href={withLang(`/${stripLangFromId(item.entry.id)}`)}>
										<span class="quick-path-label">{item.title}</span>
										<strong>{item.entry.data.title}</strong>
										<p>{item.description}</p>
										<span class="quick-path-action">Open guide</span>
									</a>
								))}
						</div>
					</section>
				)}
				{featuredGuides.length > 0 && (
					<section class="category-section" aria-labelledby="featured-guides">
						<h2 id="featured-guides">{featuredHeading}</h2>
						<div class="featured-grid">
								{featuredGuides.map((guide) => (
									<a
										class="featured-card"
										data-category={category}
										href={withLang(`/${stripLangFromId(guide.id)}`)}
									>
										{category === 'medical' && <span class="featured-card-eyebrow">Featured</span>}
										<strong>{guide.data.title}</strong>
										<p>{guide.data.description}</p>
										{category === 'medical' && <span class="featured-card-action">Read guide</span>}
									</a>
								))}
							</div>
						</section>
				)}
				{topics.length > 0 && (
					<section class="category-section" aria-labelledby="browse-by-topic">
						<h2 id="browse-by-topic">Browse by topic</h2>
						{category === 'medical' && (
							<p class="topic-intro">
								Start with the question you are trying to solve right now, then move into the detailed
								guide that matches your situation.
							</p>
						)}
						<div class="topic-grid" data-category={category}>
							{topics.map((topic) => {
								if (topic.entries.length === 0) return null;
								return (
									<div class="topic-card">
										<div class="topic-card-header">
											<h3>{topic.title}</h3>
										</div>
										<ul>
											{topic.entries.map((entry) => (
												<li>
													<a href={withLang(`/${stripLangFromId(entry.id)}`)}>{entry.data.title}</a>
												</li>
											))}
										</ul>
									</div>
								);
							})}
						</div>
					</section>
				)}
				{guides.length > 0 ? (
					<>
						<h2 id="all-guides">{allHeading}</h2>
						<ul class="category-list">
							{guides.map((guide) => (
								<li>
									<a href={withLang(`/${stripLangFromId(guide.id)}`)}>{guide.data.title}</a>
									<p>{guide.data.description}</p>
									<p class="category-meta">
										Last updated <FormattedDate date={guide.data.lastUpdated} />
									</p>
								</li>
							))}
						</ul>
					</>
				) : (
					<p>No guides are available in this category yet.</p>
				)}
			</main>
		</Layout>
	</body>
</html>
